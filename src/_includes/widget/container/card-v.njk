<a
    href="{{ card_url | url }}"
    class="card card-v {{ card_bgAccent or section_bgAccent }}">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="card-bookmark">
        <path d="M17,3H7A2,2 0 0,0 5,5V21L12,18L19,21V5C19,3.89 18.1,3 17,3Z" />
    </svg>
    <div class="card-content">
        <label class="title {{ card_textAccent or section_textAccent or 'text-zinc-900' }}">{{ card_title }}</label>
    </div>
</a>